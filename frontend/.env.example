# Vela frontend — environment template
# Copy this file to `.env.local` and fill in the values. `.env.local` is gitignored.

# ── Vela backend ────────────────────────────────────────────────────────────
# Base URL of the Vela FastAPI backend. Used by src/services/velaApi.ts for all
# recommendation / arena / evaluation / taste / galaxy / chat calls.
# Local dev default:
VITE_API_URL=http://localhost:8000

# ── TMDB (browse pages) ─────────────────────────────────────────────────────
# The original template's movie/TV browse pages (Home rails fallback, /movie,
# /tv catalog, Detail) still read from TMDB. We keep TMDB for poster imagery.
VITE_TMDB_API_BASE_URL=https://api.themoviedb.org/3
# Your TMDB v3 API key (https://www.themoviedb.org/settings/api). Required for
# the TMDB-backed browse pages to load. Leave blank if you only use the Vela
# backend pages.
VITE_API_KEY=
